# =============================================================================
# Stripe 收费配置（复制到 .env 并填入真实值）
# =============================================================================

# 1. Stripe Dashboard → 开发者 → API 密钥 → secret key（测试用 sk_test_，正式用 sk_live_）
STRIPE_SECRET_KEY=sk_test_your_key_here

# 2. Stripe Dashboard → 开发者 → Webhook → 添加端点后复制「签名密钥」
#    本地测试：运行 stripe listen --forward-to localhost:4000/api/subscriptions/webhook 获取临时 whsec_xxx
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# 3. Stripe Dashboard → 产品 → 创建价格后复制 Price ID（格式 price_xxx）
#    个人版：$9.99/月、$99.90/年
STRIPE_PRICE_PERSONAL_MONTHLY=price_your_price_id
STRIPE_PRICE_PERSONAL_YEARLY=price_your_price_id

# 4. 专业版：$29.99/月、$299.90/年
STRIPE_PRICE_PRO_MONTHLY=price_your_price_id
STRIPE_PRICE_PRO_YEARLY=price_your_price_id

# 5. 测试套餐：$0.10/月（用于支付流程测试）
STRIPE_PRICE_TEST_MONTHLY=price_your_price_id

# 6. Checkout 成功/取消回调地址（本地开发用 localhost，生产用真实域名）
FRONTEND_URL=http://localhost:3000


# MySQL（若 database.type=mysql）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=x_computer
